{
    "compilerOptions": {
        "composite": true,
        "module": "ESNext",
        "target": "ESNext",
        "outDir": "dist-electron",
        "rootDir": "electron",
        "sourceMap": false,
        "lib": ["ESNext", "DOM" , "DOM.Iterable"],
        "types": [
            "node",
            "electron"
        ],
        "esModuleInterop": true,
        "moduleResolution": "bundler",
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ]
        }
    },
    "include": [
        "electron/**/*"
    ]
}
